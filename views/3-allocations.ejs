<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/styles.css" />
  <title>Current Allocations</title>
</head>
<body class="container">

  <!-- Hero Banner -->
  <div class="hero-banner">
    <img src="/images/allocations.jpg" class="hero-image" alt="Device Allocations" />
    <h1 class="hero-text">Current Allocations</h1>
  </div>

  <!-- Load Allocations Button -->
  <button id="viewBtn" class="btn" style="margin-bottom: 20px;">Load Allocations</button>

  <!-- Allocations Table -->
  <table id="allocTable" class="table" style="display: none;">
    <thead>
      <tr>
        <th>Employee</th>
        <th>Device</th>
        <th>Allocated Date</th>
      </tr>
    </thead>
    <tbody id="tableBody"></tbody>
  </table>

  <script src="/js/allocation.js"></script>
</body>
</html>
