<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Active Allocations</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">
</head>
<body>
<header>
  <nav>
    <a href="/" class="logo"><span class="dot"></span>Asset Manager</a>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/allocate">Allocate</a>
      <a href="/deallocate">Deallocate</a>
      <a href="/allocations" class="active">Active Allocations</a>
    </div>
  </nav>
</header>

<main class="wrap">
  <h1>Active Allocations</h1>
  <p class="subtitle">Every device currently checked out, and who has it.</p>

  <div class="panel">
    <div class="panel-head">
      <span class="panel-title">All Active Allocations</span>
      <div class="search-box"><input id="allocSearch" placeholder="Search by name, brand, model..."></div>
    </div>
    <table>
      <thead><tr><th>Employee</th><th>Brand</th><th>Model</th><th>Allocated Date</th></tr></thead>
      <tbody id="allocTable">
        <tr class="empty-row"><td colspan="4"><span class="spinner"></span> Loading...</td></tr>
      </tbody>
    </table>
  </div>
</main>

<script src="/app.js"></script>
<script>
  async function loadAllocations() {
    const rows = await apiGet('/api/allocations');
    const tbody = document.getElementById('allocTable');
    tbody.innerHTML = rows.length
      ? rows.map(r => `
          <tr class="alloc-row" data-search="${(r.employee + ' ' + r.brand + ' ' + r.model).toLowerCase()}">
            <td>${r.employee}</td><td>${r.brand}</td><td>${r.model}</td>
            <td>${new Date(r.allocated_date).toLocaleDateString()}</td>
          </tr>`).join('')
      : '<tr class="empty-row"><td colspan="4">No active allocations.</td></tr>';
    attachSearch('allocSearch', '.alloc-row', (row, q) => row.dataset.search.includes(q));
  }
  loadAllocations();
</script>
</body>
</html>
